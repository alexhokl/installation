#!/bin/bash

source $HOME/git/installation/functions_common

update_all() {
  sudo pacman -Sy --noconfirm archlinux-keyring;
  sudo pacman -Syu --noconfirm;
  configure_rust
  yay -Syu --noconfirm --answerclean A --answerdiff N;
  install_go_packages
  install_cargo_packages
  install_opam_packages
  install_vscode_extensions
  install_dotnet_tools
  install_gh_extensions
  install_gems
  update_python_packages
  update_npm_packages
  install_gcpdiag
  flutter upgrade
  install_slack_cli
  install_reddit_tui
  install_hugo
  install_mermaid_ascii
}

install_all() {
  install_have
  install_sc_im
  install_another_redis_desktop_manager
  install_gcpdiag
  configure_rust
  install_slack_cli
  install_reddit_tui
  install_claude_code
  install_mermaid_ascii
}

install_azure_data_studio_extensions() {
  cat $HOME/git/installation/azuredatastudio.extensions | xargs -n 1 /usr/bin/azuredatastudio --force --install-extension
}

install_sc_im() {
  pushd $PWD

  git clone https://github.com/jmcnamara/libxlsxwriter.git $HOME/git/libxlsxwriter
  cd $HOME/git/libxlsxwriter
  make
  sudo make install
  git clone https://github.com/andmarti1424/sc-im.git $HOME/git/sc-im
  cd $HOME/git/sc-im
  make
  sudo make install

  popd
}

install_have() {
  LOCAL_BIN=/usr/local/bin

  sudo curl -o $LOCAL_BIN/have -sSL https://misc.j3ss.co/binaries/have
  sudo chmod a+x $LOCAL_BIN/have
}

install_opam_packages() {
  opam update
  cat $HOME/git/installation/opam_packages | xargs -n 1 opam install -y
}

install_another_redis_desktop_manager() {
  INSTALL_DIR=$(mktemp -d)
  _VERSION=$(jq -r '."qishibo/AnotherRedisDesktopManager"' $HOME/git/installation/versions_on_github.json)

  curl -o $INSTALL_DIR/another-redis-desktop-manager -sSL https://github.com/qishibo/AnotherRedisDesktopManager/releases/download/v${_VERSION}/Another-Redis-Desktop-Manager.${_VERSION}.AppImage
  chmod u+x $INSTALL_DIR/another-redis-desktop-manager
  sudo /bin/mv -f $INSTALL_DIR/another-redis-desktop-manager /usr/bin/
}

install_mermaid_ascii() {
  INSTALL_DIR=$(mktemp -d)
  LOCAL_BIN=/usr/local/bin
  _VERSION=$(jq -r '."AlexanderGrooff/mermaid-ascii"' $HOME/git/installation/versions_on_github.json)

  curl -o $INSTALL_DIR/mermaid-ascii.tar.gz -sSL https://github.com/AlexanderGrooff/mermaid-ascii/releases/download/${_VERSION}/mermaid-ascii_Linux_x86_64.tar.gz
  tar xzf $INSTALL_DIR/mermaid-ascii.tar.gz -C $INSTALL_DIR/
  sudo /bin/mv -f $INSTALL_DIR/mermaid-ascii $LOCAL_BIN/
}

install_gems() {
  cat $HOME/git/installation/gem-list | xargs -n 1 gem install
}

configure_rust() {
  rustup install stable
}

install_d2() {
  curl -fsSL https://d2lang.com/install.sh | sh -s --
}

install_yq() {
  INSTALL_DIR=$(mktemp -d)

  curl -o $INSTALL_DIR/yq -sSL https://github.com/mikefarah/yq/releases/latest/download/yq_linux_amd64
  chmod +x $INSTALL_DIR/yq
  sudo /bin/mv -f $INSTALL_DIR/yq /usr/local/bin/
}

install_asdf() {
  pushd $PWD

  cd $HOME/git
  _REPO_DIRECTORY=$HOME/git/asdf-vm

  if [ -d "${_REPO_DIRECTORY}" ]; then
    rm -rf $_REPO_DIRECTORY
  fi
  git clone https://aur.archlinux.org/asdf-vm.git && cd asdf-vm && makepkg -si

  popd
}
